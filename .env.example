# === Official Data Layer — Environment Variables (только секреты) ===
# Copy this file to .env and fill in your values.
# Все не-секретные настройки — в config.yaml (см. config.example.yaml)

# Yandex Vision OCR API key (секрет)
OCR_YA_KEY_SECRET=

# LangFuse (observability) — опционально
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LangFuse auth (обязательно, если включён langfuse сервис в docker-compose)
NEXTAUTH_SECRET=
SALT=
