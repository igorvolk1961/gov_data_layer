# === Official Data Layer — Environment Variables ===
# Copy this file to .env and fill in your values.

# Qdrant (векторный поиск)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis (кэш)
REDIS_HOST=localhost
REDIS_PORT=6379

# LangFuse (observability) — опционально
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LangFuse auth (обязательно, если включён langfuse сервис в docker-compose)
NEXTAUTH_SECRET=
SALT=

# SQLite (метаданные и иерархия)
DATABASE_URL=sqlite:///data/official_data.db

# Логирование
LOG_LEVEL=INFO
LOG_CLEAR_ON_START=false       # Очищать файл traces.log при старте
LOG_FILE=data/traces.log       # Файл логов (fallback, если LangFuse недоступен)

# MCP сервер
MCP_HOST=0.0.0.0
MCP_PORT=8000
